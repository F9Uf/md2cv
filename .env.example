# --- Server-side (Vercel serverless function env; unprefixed, NEVER sent to the browser) ---
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# --- Client-side (VITE_ prefix exposes to the browser via import.meta.env) ---
# Public OAuth client id, used to build the authorize URL:
VITE_GITHUB_CLIENT_ID=your_github_client_id
# Token-exchange endpoint (AUTH-02 — change host without editing source):
VITE_AUTH_ENDPOINT=http://localhost:3000/api/github-auth
