{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "outDir": ".vercel/output"
  },
  "include": ["./**/*.ts"],
  "exclude": ["../node_modules"]
}
